{
  "name": "display",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["apps/web", "apps/backend"],
  "scripts": {
    "dev": "concurrently -n web,backend -c blue,green \"npm run dev:web\" \"npm run dev:backend\"",
    "dev:web": "npm run dev --workspace=@display/web",
    "dev:backend": "npm run dev --workspace=@display/backend",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "check": "npm run typecheck",
    "db:up": "docker compose up -d mysql",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f mysql",
    "mobile:build": "cd apps/mobile && ./gradlew assembleDebug"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "engines": { "node": ">=22" }
}
