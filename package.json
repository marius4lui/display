{
  "name": "display",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm run dev --workspace=@display/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "check": "npm run typecheck",
    "test": "npm run test --workspaces --if-present",
    "collector:once": "node -e \"fetch('http://localhost:3000/api/internal/collector',{method:'POST',headers:{Authorization:'Bearer '+process.env.COLLECTOR_TOKEN}}).then(async r=>{console.log(await r.text());process.exit(r.ok?0:1)})\"",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:status": "supabase status",
    "mobile:build": "cd apps/mobile && ./gradlew assembleDebug",
    "mobile:release": "cd apps/mobile && ./gradlew assembleRelease"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "postcss": "^8.5.10"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
