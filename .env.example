# Output of `supabase status` for local development, or the equivalent values
# from the self-hosted production Supabase installation.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-with-self-hosted-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-self-hosted-service-role-key
PUBLIC_APP_URL=http://localhost:3000
WEB_PORT=3000
# Erzeugen mit: openssl rand -base64 32
SECRET_STORE_MASTER_KEY=
# Erzeugen mit: openssl rand -hex 32
COLLECTOR_TOKEN=
